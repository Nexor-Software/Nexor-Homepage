---
import Layout from "@/layouts/Layout.astro";
import { AboutStatsCards } from "@/components/AboutStatsCards";
import { AboutMissionVisionCard } from "@/components/AboutMissionVisionCard";
import { Target, Award, Clock } from "lucide-react";

const currentLocale = 'en';

const translations = {
  en: {
    title: "About",
    subtitle: "We are passionate about creating innovative software solutions that empower businesses to thrive in the digital age.",
    storyTitle: "Our",
    storyTitleHighlight: "Story",
    storyPara1: "Founded with a vision to bridge the gap between innovative technology and business success, Nexor Software has been at the forefront of digital transformation for 2 years. We believe that every business deserves access to cutting-edge software solutions that drive growth and efficiency.",
    storyPara2: "Our team of experienced software developers, designers, and video editors work collaboratively to deliver solutions that not only meet current needs but also scale for future growth.",
    missionTitle: "Our Mission",
    missionText: "To empower businesses with innovative software solutions that drive digital transformation and create lasting value for our clients and their customers.",
    visionTitle: "Our Vision",
    visionText: "To be the leading software development partner for businesses seeking to leverage technology for competitive advantage and sustainable growth.",
    achievementsTitle: "Our",
    achievementsTitleHighlight: "Achievements",
    projectsLabel: "Successfully Launched Projects",
    experienceLabel: "Years Experience",
    supportLabel: "Excellent Support"
  }
};

const t = translations[currentLocale];
---

<Layout>
  {/* Hero Section */}
  <section class="relative pt-32 pb-20 px-8 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0C1C2C] via-[#0F2235] to-[#0C1C2C]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(48,214,196,0.1),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(48,214,196,0.05),transparent_50%)]"></div>
    <div class="relative max-w-6xl mx-auto text-center">
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-[#30D6C4]/10 border border-[#30D6C4]/20 text-[#30D6C4] text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-[#30D6C4] rounded-full mr-2 animate-pulse"></span>
        About Us
      </div>
      <h1 class="text-5xl md:text-7xl font-oswald font-normal text-white leading-tight mb-8">
        {t.title} <span class="text-[#30D6C4]">Nexor Software</span>
      </h1>
      <p class="text-xl md:text-2xl font-inter text-[#B0C4D4] max-w-4xl mx-auto leading-relaxed mb-12">
        {t.subtitle}
      </p>
      <div class="w-24 h-1 bg-gradient-to-r from-[#30D6C4] to-transparent mx-auto"></div>
    </div>
  </section>

  {/* Our Story */}
  <section class="py-24 px-8 bg-[#0C1C2C]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-oswald font-normal text-white mb-6">
            {t.storyTitle} <span class="text-[#30D6C4]">{t.storyTitleHighlight}</span>
          </h2>
          <p class="text-lg text-[#B0C4D4] mb-6 font-inter leading-relaxed">
            {t.storyPara1}
          </p>
          <p class="text-lg text-[#B0C4D4] font-inter leading-relaxed">
            {t.storyPara2}
          </p>
        </div>
        <div class="relative group">
          <AboutMissionVisionCard
            client:load
            currentLocale={currentLocale}
            missionTitle={t.missionTitle}
            missionText={t.missionText}
            visionTitle={t.visionTitle}
            visionText={t.visionText}
          />
        </div>
      </div>
    </div>
  </section>

  {/* Stats Section */}
  <section class="py-24 px-8 bg-[#0F2235]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-4xl font-oswald font-normal text-white mb-6">
          {t.achievementsTitle} <span class="text-[#30D6C4]">{t.achievementsTitleHighlight}</span>
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-[#30D6C4] to-transparent mx-auto"></div>
      </div>
      <AboutStatsCards client:load currentLocale={currentLocale} />
    </div>
  </section>
</Layout>
