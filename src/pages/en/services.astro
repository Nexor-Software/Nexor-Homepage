---
import Layout from "@/layouts/Layout.astro";
import { ServicesCards } from "@/components/ServicesCards";
---

<Layout>
  {/* Hero Section */}
  <section class="relative pt-32 pb-20 px-8 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0C1C2C] via-[#0F2235] to-[#0C1C2C]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(48,214,196,0.1),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(48,214,196,0.05),transparent_50%)]"></div>
    <div class="relative max-w-6xl mx-auto text-center">
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-[#30D6C4]/10 border border-[#30D6C4]/20 text-[#30D6C4] text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-[#30D6C4] rounded-full mr-2 animate-pulse"></span>
        Services
      </div>
      <h1 class="text-5xl md:text-7xl font-oswald font-normal text-white leading-tight mb-8">
        Our <span class="text-[#30D6C4]">Services</span>
      </h1>
      <p class="text-xl md:text-2xl font-inter text-[#B0C4D4] max-w-4xl mx-auto leading-relaxed mb-12">
        We offer comprehensive software solutions to transform your business and drive digital innovation.
      </p>
      <div class="w-24 h-1 bg-gradient-to-r from-[#30D6C4] to-transparent mx-auto"></div>
    </div>
  </section>

  {/* Services Grid */}
  <section class="py-1 px-8 bg-[#0C1C2C]">
    <div class="max-w-7xl mx-auto">
      <ServicesCards client:load currentLocale="en" />
    </div>
  </section>
</Layout>
